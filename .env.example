# ─── Gemini API (必填) ────────────────────────────────────
# 从 https://aistudio.google.com/apikey 获取
GOOGLE_API_KEY=your-gemini-api-key-here

# ─── Semantic Scholar API (可选，推荐) ────────────────────
# 免费申请: https://www.semanticscholar.org/product/api#api-key
# 不设置也能用，但速率限制较严 (100 req/5min)
# 设置后提升至 1 req/sec 持续调用
S2AG_API_KEY=

# ─── 搜索参数 (可选) ──────────────────────────────────────
# SEARCH_MIN_YEAR=2020
# SEARCH_MAX_YEAR=2026
# SEARCH_FETCH_LIMIT=100
# SEARCH_PROCESS_LIMIT=30
# SEARCH_RECENCY_WEIGHT=0.65

# ─── 过滤规则 (可选) ──────────────────────────────────────
# 学科领域过滤，逗号分隔。留空则搜索所有领域。
# 可选值: Computer Science, Physics, Mathematics, Biology,
#         Medicine, Chemistry, Engineering, Environmental Science,
#         Materials Science, Psychology, Economics, Business,
#         Political Science, Sociology, Geography, History,
#         Art, Philosophy, Linguistics, Education
# 示例: FILTER_FIELDS_OF_STUDY=Computer Science
# 示例: FILTER_FIELDS_OF_STUDY=Computer Science,Engineering
FILTER_FIELDS_OF_STUDY=

# 最低引用数过滤（通用规则）
# 设为 0 则不过滤引用数，设为 5 则只保留≥5次引用的论文
FILTER_MIN_CITATIONS=0

# 引用豁免年份：该年份(含)之后的论文不受 min_citations 限制
# 因为新论文还没来得及积累引用量
# 例: 设为 2024，则 2024/2025/2026 的论文即使引用<5也会保留
FILTER_CITATION_EXEMPT_YEAR=2024

# 新论文独立配额（去马太效应）
# 当总论文数 > process_limit 时，启用双池选拔：
#   - 新论文池 (>= exempt_year): 按引用数取 top recent_limit
#   - 经典论文池 (< exempt_year): 用 log 压缩引用数排序（去马太效应）
# 设为 0 则不限制新论文数量
FILTER_RECENT_LIMIT=15

# ─── 引用链扩展 (可选) ────────────────────────────────────
# 用关键词搜索中最高引的论文，通过其引用/被引关系发现更多相关文献
# 类似于学术研究中的 "citation snowballing" 技术
EXPAND_ENABLED=true

# 种子论文数量：取引用数最高的 N 篇作为种子
EXPAND_SEED_COUNT=3

# 扩展方向：references (这篇论文引用了谁),
#           citations (谁引用了这篇论文),
#           both (双向，推荐)
EXPAND_DIRECTION=both

# 每个种子每个方向最多获取多少篇
EXPAND_PER_SEED_LIMIT=20

# ─── 模型配置 (可选) ──────────────────────────────────────
# LLM_FLASH_MODEL=gemini-2.5-flash
# LLM_PRO_MODEL=gemini-2.5-pro
